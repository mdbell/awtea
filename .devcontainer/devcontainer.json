{
  "name": "AWTea Development",
  "build": {
    "dockerfile": "Dockerfile",
    "context": "."
  },
  
  "customizations": {
    "vscode": {
      "extensions": [
        "vscjava.vscode-java-pack",
        "vscjava.vscode-gradle",
        "redhat.java",
        "vscjava.vscode-java-debug",
        "vscjava.vscode-java-test",
        "denoland.vscode-deno"
      ],
      "settings": {
        "deno.enable": false,
        "deno.enablePaths": [
          "./awtea-graphics/src/test/deno"
        ]
      }
    }
  },

  "forwardPorts": [8080, 3000],

  "postCreateCommand": "source /home/vscode/.sdkman/bin/sdkman-init.sh && source /opt/emsdk/emsdk_env.sh && java -version && ./gradlew -v && deno --version && emcc --version",

  "remoteUser": "vscode"
}
